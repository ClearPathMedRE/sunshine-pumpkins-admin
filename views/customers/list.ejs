<%
  const isAdmin = locals.currentUser && currentUser.role === 'admin';
  function formatCurrency(val) {
    return '$' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>

<!-- Market Selector -->
<div class="d-flex justify-content-end mb-3">
  <%- include('../partials/market-selector') %>
</div>

<!-- Search and Filter Bar -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/customers" class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label small">Search</label>
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Name, email, or phone..." value="<%= locals.filters && filters.search ? filters.search : '' %>">
      </div>
      <div class="col-md-3">
        <label class="form-label small">Tag</label>
        <select name="tag" class="form-select form-select-sm">
          <option value="">All Tags</option>
          <% if (locals.tags) { tags.forEach(function(tag) { %>
            <option value="<%= tag %>" <%= (locals.filters && filters.tag === tag) ? 'selected' : '' %>><%= tag %></option>
          <% }); } %>
        </select>
      </div>
      <div class="col-md-2">
        <button type="submit" class="btn btn-sm w-100" style="background-color: var(--pumpkin); color: #fff;">
          <i class="bi bi-search me-1"></i> Search
        </button>
      </div>
      <% if (isAdmin) { %>
        <div class="col-md-2">
          <a href="/customers/export" class="btn btn-sm btn-outline-secondary w-100">
            <i class="bi bi-download me-1"></i> Export CSV
          </a>
        </div>
      <% } %>
    </form>
  </div>
</div>

<!-- Customers Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Market</th>
            <th>Orders</th>
            <th>Total Spend</th>
            <th>Tags</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (locals.customers && customers.length) { %>
            <% customers.forEach(function(cust) { %>
              <tr>
                <td><a href="/customers/<%= cust.id %>"><%= cust.first_name %> <%= cust.last_name %></a></td>
                <td><%= cust.email %></td>
                <td><%= cust.phone || 'N/A' %></td>
                <td><%= cust.market_name || 'N/A' %></td>
                <td><%= cust.order_count || 0 %></td>
                <td><%= formatCurrency(cust.total_spend) %></td>
                <td>
                  <% if (cust.tags && cust.tags.length) { %>
                    <% cust.tags.forEach(function(tag) { %>
                      <span class="badge bg-secondary me-1"><%= tag %></span>
                    <% }); %>
                  <% } %>
                </td>
                <td>
                  <a href="/customers/<%= cust.id %>" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-eye"></i> View
                  </a>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="text-center text-muted py-4">No customers found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/pagination', { page: locals.page || 1, pages: locals.pages || 1, baseUrl: '/customers' }) %>
