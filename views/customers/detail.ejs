<%
  const isAdmin = locals.currentUser && currentUser.role === 'admin';
  const statusColors = {
    booked: 'primary', photo_requested: 'warning', design_prep: 'info',
    scheduled: 'secondary', installed: 'success', completed: 'success', cancelled: 'danger'
  };
  function statusBadge(status) {
    const color = statusColors[status] || 'secondary';
    const label = (status || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    return '<span class="badge bg-' + color + '">' + label + '</span>';
  }
  function formatCurrency(val) {
    return '$' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>

<div class="row g-4">
  <!-- Customer Info -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold d-flex justify-content-between align-items-center">
        <span><i class="bi bi-person me-1"></i> Customer Info</span>
        <a href="/customers/<%= customer.id %>/edit" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-pencil"></i> Edit
        </a>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Name</dt>
          <dd class="col-sm-8"><%= customer.first_name %> <%= customer.last_name %></dd>
          <dt class="col-sm-4">Email</dt>
          <dd class="col-sm-8"><%= customer.email %></dd>
          <dt class="col-sm-4">Phone</dt>
          <dd class="col-sm-8"><%= customer.phone || 'N/A' %></dd>
          <dt class="col-sm-4">Address</dt>
          <dd class="col-sm-8"><%= customer.address || '' %><% if (customer.city) { %>, <%= customer.city %><% } %><% if (customer.state) { %>, <%= customer.state %><% } %> <%= customer.zip || '' %></dd>
          <dt class="col-sm-4">Neighborhood</dt>
          <dd class="col-sm-8"><%= customer.neighborhood || 'N/A' %></dd>
          <dt class="col-sm-4">Market</dt>
          <dd class="col-sm-8"><span class="badge" style="background-color: var(--pumpkin);"><%= customer.market_name || 'N/A' %></span></dd>
          <dt class="col-sm-4">Source</dt>
          <dd class="col-sm-8"><span class="badge bg-info"><%= customer.source || 'N/A' %></span></dd>
          <% if (customer.notes) { %>
            <dt class="col-sm-4">Notes</dt>
            <dd class="col-sm-8"><%= customer.notes %></dd>
          <% } %>
        </dl>
      </div>
    </div>

    <!-- Lifetime Spend -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body text-center">
        <h6 class="text-muted mb-1">Lifetime Spend</h6>
        <h2 class="fw-bold" style="color: var(--pumpkin);"><%= formatCurrency(locals.lifetimeSpend) %></h2>
      </div>
    </div>

    <!-- Tags -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-tags me-1"></i> Tags
      </div>
      <div class="card-body">
        <div class="mb-2">
          <% if (locals.customerTags && customerTags.length) { %>
            <% customerTags.forEach(function(tag) { %>
              <span class="badge bg-secondary me-1 mb-1">
                <%= tag %>
                <% if (isAdmin) { %>
                  <a href="/customers/<%= customer.id %>/tags/remove?tag=<%= encodeURIComponent(tag) %>" class="text-white ms-1 text-decoration-none" title="Remove tag">&times;</a>
                <% } %>
              </span>
            <% }); %>
          <% } else { %>
            <span class="text-muted">No tags</span>
          <% } %>
        </div>
        <% if (isAdmin) { %>
          <form action="/customers/<%= customer.id %>/tags" method="POST" class="mt-2">
            <div class="input-group input-group-sm">
              <input type="text" name="tag" class="form-control" placeholder="Add tag..." required>
              <button type="submit" class="btn btn-outline-secondary">
                <i class="bi bi-plus"></i>
              </button>
            </div>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Right Column -->
  <div class="col-lg-7">
    <!-- Order History -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-receipt me-1"></i> Order History
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Order #</th>
                <th>Package</th>
                <th>Total</th>
                <th>Status</th>
                <th>Date</th>
              </tr>
            </thead>
            <tbody>
              <% if (locals.orders && orders.length) { %>
                <% orders.forEach(function(order) { %>
                  <tr>
                    <td><a href="/orders/<%= order.id %>">#<%= order.order_number || order.id %></a></td>
                    <td><%= order.package_name %></td>
                    <td><%= formatCurrency(order.total) %></td>
                    <td><%- statusBadge(order.status) %></td>
                    <td><%= new Date(order.created_at).toLocaleDateString('en-US') %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="5" class="text-center text-muted py-3">No orders</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Email Log -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-envelope me-1"></i> Email Log
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Date</th>
                <th>Subject</th>
                <th>Template</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% if (locals.emailLog && emailLog.length) { %>
                <% emailLog.forEach(function(log) { %>
                  <tr>
                    <td><%= new Date(log.sent_at).toLocaleDateString('en-US') %></td>
                    <td><%= log.subject %></td>
                    <td><%= log.template %></td>
                    <td>
                      <span class="badge bg-<%= log.status === 'sent' ? 'success' : 'danger' %>"><%= log.status %></span>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="4" class="text-center text-muted py-3">No emails sent</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="mt-2">
  <a href="/customers" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i> Back to Customers
  </a>
</div>
