<%
  const statusColors = {
    booked: 'primary',
    photo_requested: 'warning',
    design_prep: 'info',
    scheduled: 'secondary',
    installed: 'success',
    completed: 'success',
    cancelled: 'danger'
  };

  function statusBadge(status) {
    const color = statusColors[status] || 'secondary';
    const label = (status || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    return '<span class="badge bg-' + color + '">' + label + '</span>';
  }

  function formatCurrency(val) {
    return '$' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>

<!-- Metric Cards -->
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#E8621A20;">
            <i class="bi bi-receipt fs-4" style="color: var(--pumpkin);"></i>
          </div>
          <div class="ms-3">
            <h6 class="text-muted mb-0">Total Orders</h6>
            <h3 class="mb-0 fw-bold"><%= locals.totalOrders || 0 %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#19875420;">
            <i class="bi bi-currency-dollar fs-4 text-success"></i>
          </div>
          <div class="ms-3">
            <h6 class="text-muted mb-0">Revenue</h6>
            <h3 class="mb-0 fw-bold"><%= formatCurrency(locals.totalRevenue) %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#0d6efd20;">
            <i class="bi bi-graph-up fs-4 text-primary"></i>
          </div>
          <div class="ms-3">
            <h6 class="text-muted mb-0">Avg Order Value</h6>
            <h3 class="mb-0 fw-bold"><%= formatCurrency(locals.avgOrderValue) %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body">
        <div class="d-flex align-items-center">
          <div class="flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#6f42c120;">
            <i class="bi bi-people fs-4" style="color:#6f42c1;"></i>
          </div>
          <div class="ms-3">
            <h6 class="text-muted mb-0">Total Customers</h6>
            <h3 class="mb-0 fw-bold"><%= locals.totalCustomers || 0 %></h3>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Orders by Status Chart -->
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Orders by Status</div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <canvas id="statusChart" style="max-height: 280px;"></canvas>
      </div>
    </div>
  </div>

  <!-- Upcoming Installs -->
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Upcoming Installs (Next 7 Days)</div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>Date</th>
                <th>Customer</th>
                <th>Package</th>
                <th>Crew</th>
              </tr>
            </thead>
            <tbody>
              <% if (locals.upcomingInstalls && upcomingInstalls.length) { %>
                <% upcomingInstalls.forEach(function(inst) { %>
                  <tr>
                    <td><%= new Date(inst.install_date).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) %></td>
                    <td><a href="/orders/<%= inst.order_id %>"><%= inst.customer_name %></a></td>
                    <td><%= inst.package_name %></td>
                    <td><%= inst.crew || '<span class="text-muted">Unassigned</span>' %></td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr><td colspan="4" class="text-center text-muted py-3">No upcoming installs</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Recent Orders -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white fw-semibold">Recent Orders</div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Order #</th>
            <th>Customer</th>
            <th>Package</th>
            <th>Total</th>
            <th>Status</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (locals.recentOrders && recentOrders.length) { %>
            <% recentOrders.forEach(function(order) { %>
              <tr>
                <td><a href="/orders/<%= order.id %>">#<%= order.order_number || order.id %></a></td>
                <td><%= order.customer_name %></td>
                <td><%= order.package_name %></td>
                <td><%= formatCurrency(order.total) %></td>
                <td><%- statusBadge(order.status) %></td>
                <td><%= new Date(order.created_at).toLocaleDateString('en-US') %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="6" class="text-center text-muted py-3">No recent orders</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<script>
  const byStatus = <%- JSON.stringify(locals.byStatus || {}) %>;
  const statusLabels = Object.keys(byStatus).map(s => s.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()));
  const statusData = Object.values(byStatus);
  const statusColorMap = {
    booked: '#0d6efd',
    photo_requested: '#ffc107',
    design_prep: '#0dcaf0',
    scheduled: '#6c757d',
    installed: '#198754',
    completed: '#198754',
    cancelled: '#dc3545'
  };
  const bgColors = Object.keys(byStatus).map(s => statusColorMap[s] || '#6c757d');

  if (document.getElementById('statusChart')) {
    new Chart(document.getElementById('statusChart'), {
      type: 'doughnut',
      data: {
        labels: statusLabels,
        datasets: [{
          data: statusData,
          backgroundColor: bgColors,
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'bottom', labels: { boxWidth: 12 } }
        }
      }
    });
  }
</script>
