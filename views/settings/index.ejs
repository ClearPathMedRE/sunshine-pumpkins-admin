<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0">Settings</h4>
</div>

<!-- Promo Pricing Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="bi bi-tag me-2"></i>Promotional Pricing</h5>
  </div>
  <div class="card-body">
    <form action="/settings/promo" method="POST">
      <div class="row align-items-end">
        <div class="col-md-3 mb-3">
          <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="promoEnabled" name="promo_enabled" value="on" <%= promoEnabled ? 'checked' : '' %>>
            <label class="form-check-label" for="promoEnabled">
              <strong>Promo Pricing Enabled</strong>
            </label>
          </div>
          <small class="text-muted">When enabled, promotional prices are active on the website.</small>
        </div>
        <div class="col-md-3 mb-3">
          <label for="promoEndDate" class="form-label">Promo End Date</label>
          <input type="date" class="form-control" id="promoEndDate" name="promo_end_date" value="<%= promoEndDate || '' %>">
        </div>
        <div class="col-md-3 mb-3">
          <button type="submit" class="btn" style="background-color: var(--pumpkin); color: #fff;">
            <i class="bi bi-check-lg me-1"></i> Save Promo Settings
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<!-- Discount Codes Card -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex justify-content-between align-items-center">
    <h5 class="mb-0"><i class="bi bi-percent me-2"></i>Discount Codes</h5>
    <a href="/settings/codes/new" class="btn btn-sm" style="background-color: var(--pumpkin); color: #fff;">
      <i class="bi bi-plus-lg me-1"></i> Add Code
    </a>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Code</th>
            <th>Type</th>
            <th>Value</th>
            <th>Description</th>
            <th>Uses</th>
            <th>Expires</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (codes && codes.length) { %>
            <% codes.forEach(function(c) { %>
              <tr>
                <td><code class="fw-bold"><%= c.code %></code></td>
                <td><span class="badge bg-info"><%= c.discount_type %></span></td>
                <td>
                  <% if (c.discount_type === 'percent') { %>
                    <%= c.discount_value %>%
                  <% } else { %>
                    $<%= c.discount_value.toFixed(2) %>
                  <% } %>
                </td>
                <td class="text-muted small"><%= c.description || '-' %></td>
                <td><%= c.times_used %><%= c.max_uses ? ' / ' + c.max_uses : '' %></td>
                <td><%= c.expires_at ? new Date(c.expires_at).toLocaleDateString('en-US') : 'Never' %></td>
                <td>
                  <span class="badge bg-<%= c.active ? 'success' : 'secondary' %>"><%= c.active ? 'Active' : 'Inactive' %></span>
                </td>
                <td>
                  <div class="btn-group btn-group-sm">
                    <a href="/settings/codes/<%= c.id %>/edit" class="btn btn-outline-primary" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <form action="/settings/codes/<%= c.id %>/toggle" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-outline-<%= c.active ? 'warning' : 'success' %>" title="<%= c.active ? 'Deactivate' : 'Activate' %>">
                        <i class="bi bi-<%= c.active ? 'pause' : 'play' %>"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="8" class="text-center text-muted py-4">No discount codes yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="mt-3">
  <a href="/referrals" class="btn btn-outline-secondary">
    <i class="bi bi-link-45deg me-1"></i> Manage Referral Partners
  </a>
</div>
