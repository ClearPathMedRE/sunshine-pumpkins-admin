<% locals.loadCalendar = true; %>

<!-- Market Selector -->
<div class="d-flex justify-content-end mb-3">
  <%- include('../partials/market-selector') %>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <div id="calendar"></div>
  </div>
</div>

<!-- Unscheduled Orders -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white fw-semibold">
    <i class="bi bi-clock me-1"></i> Unscheduled Orders
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Order #</th>
            <th>Customer</th>
            <th>Package</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (locals.unscheduledOrders && unscheduledOrders.length) { %>
            <% unscheduledOrders.forEach(function(order) { %>
              <tr>
                <td><a href="/orders/<%= order.id %>">#<%= order.order_number || order.id %></a></td>
                <td><%= order.customer_name %></td>
                <td><%= order.package_name %></td>
                <td><span class="badge bg-secondary"><%= (order.status || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></span></td>
                <td>
                  <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#assignModal" data-order-id="<%= order.id %>" data-order-num="<%= order.order_number || order.id %>">
                    <i class="bi bi-calendar-plus me-1"></i> Assign
                  </button>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="text-center text-muted py-3">All orders are scheduled</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Assign Modal -->
<div class="modal fade" id="assignModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/schedule/assign" method="POST">
        <input type="hidden" name="order_id" id="assignOrderId">
        <div class="modal-header">
          <h5 class="modal-title">Schedule Install - Order #<span id="assignOrderNum"></span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label for="install_date" class="form-label">Install Date</label>
            <input type="date" class="form-control" id="install_date" name="install_date" required>
          </div>
          <div class="mb-3">
            <label for="time_slot" class="form-label">Time Slot</label>
            <select class="form-select" id="time_slot" name="time_slot">
              <option value="morning">Morning</option>
              <option value="afternoon">Afternoon</option>
              <option value="all-day">All Day</option>
            </select>
          </div>
          <div class="mb-3">
            <label for="crew" class="form-label">Crew Name</label>
            <input type="text" class="form-control" id="crew" name="crew" placeholder="Crew name...">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn" style="background-color: var(--pumpkin); color: #fff;">Schedule</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Initialize FullCalendar
    const calendarEl = document.getElementById('calendar');
    if (calendarEl && typeof FullCalendar !== 'undefined') {
      const calendar = new FullCalendar.Calendar(calendarEl, {
        initialView: 'dayGridMonth',
        headerToolbar: {
          left: 'prev,next today',
          center: 'title',
          right: 'dayGridMonth,timeGridWeek,listWeek'
        },
        events: {
          url: '/schedule/api/events',
          extraParams: function() {
            const marketVal = document.getElementById('marketFilter') ? document.getElementById('marketFilter').value : '';
            return marketVal ? { market: marketVal } : {};
          }
        },
        eventClick: function(info) {
          if (info.event.extendedProps && info.event.extendedProps.order_id) {
            window.location.href = '/orders/' + info.event.extendedProps.order_id;
          }
        },
        eventDidMount: function(info) {
          const statusColorMap = {
            scheduled: '#6c757d',
            in_progress: '#E8621A',
            completed: '#198754',
            cancelled: '#dc3545'
          };
          const status = info.event.extendedProps && info.event.extendedProps.status;
          if (status && statusColorMap[status]) {
            info.el.style.backgroundColor = statusColorMap[status];
            info.el.style.borderColor = statusColorMap[status];
          }
        },
        dateClick: function(info) {
          window.location.href = '/schedule/daily/' + info.dateStr;
        }
      });
      calendar.render();
    }

    // Assign modal data
    const assignModal = document.getElementById('assignModal');
    if (assignModal) {
      assignModal.addEventListener('show.bs.modal', function(event) {
        const button = event.relatedTarget;
        document.getElementById('assignOrderId').value = button.getAttribute('data-order-id');
        document.getElementById('assignOrderNum').textContent = button.getAttribute('data-order-num');
      });
    }
  });
</script>
