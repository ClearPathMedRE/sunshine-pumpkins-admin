<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f5f5f5; font-family:Arial,Helvetica,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5; padding:20px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden;">
          <!-- Header -->
          <tr>
            <td style="background-color:#E8621A; padding:30px; text-align:center;">
              <h1 style="color:#ffffff; margin:0; font-size:28px;">&#127875; Sunshine Pumpkins</h1>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding:30px;">
              <h2 style="color:#3D2B1F; margin-top:0;">We Need a Photo of Your Porch!</h2>
              <p style="color:#555; line-height:1.6;">Hi <%= customer.first_name %>,</p>
              <p style="color:#555; line-height:1.6;">We're getting ready to design your custom pumpkin display for Order #<%= order.order_number || order.id %>. To create the perfect arrangement, we need a photo of your porch or display area.</p>

              <div style="background-color:#FFF3E0; border-left:4px solid #E8621A; padding:15px; margin:20px 0; border-radius:4px;">
                <p style="color:#3D2B1F; margin:0; font-weight:bold;">Photo Tips:</p>
                <ul style="color:#555; line-height:1.8; margin-bottom:0;">
                  <li>Take the photo during daylight hours</li>
                  <li>Show the full front porch/entryway area</li>
                  <li>Include any steps, railings, or existing decor</li>
                  <li>A straight-on shot works best</li>
                </ul>
              </div>

              <p style="color:#555; line-height:1.6;">Simply reply to this email with your photo attached, and our design team will get started right away!</p>

              <p style="color:#E8621A; font-weight:bold;">The Sunshine Pumpkins Team</p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="background-color:#3D2B1F; padding:20px; text-align:center;">
              <p style="color:#999; font-size:12px; margin:0;">Sunshine Pumpkins | St. Petersburg, FL</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
