<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f5f5f5; font-family:Arial,Helvetica,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5; padding:20px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden;">
          <!-- Header -->
          <tr>
            <td style="background-color:#E8621A; padding:30px; text-align:center;">
              <h1 style="color:#ffffff; margin:0; font-size:28px;">&#127875; Sunshine Pumpkins</h1>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding:30px;">
              <h2 style="color:#3D2B1F; margin-top:0;">Your Install Date is Confirmed!</h2>
              <p style="color:#555; line-height:1.6;">Hi <%= customer.first_name %>,</p>
              <p style="color:#555; line-height:1.6;">Great news! Your pumpkin display installation has been scheduled.</p>

              <div style="background-color:#E8621A; color:#ffffff; padding:20px; border-radius:8px; text-align:center; margin:20px 0;">
                <p style="margin:0; font-size:14px; text-transform:uppercase; letter-spacing:1px;">Install Date</p>
                <p style="margin:5px 0 0; font-size:24px; font-weight:bold;"><%= installDate %></p>
              </div>

              <table width="100%" cellpadding="8" cellspacing="0" style="border:1px solid #eee; border-radius:4px; margin:20px 0;">
                <tr style="background-color:#f8f9fa;">
                  <td style="font-weight:bold; color:#3D2B1F;">Order #</td>
                  <td><%= order.order_number || order.id %></td>
                </tr>
                <tr>
                  <td style="font-weight:bold; color:#3D2B1F;">Package</td>
                  <td><%= order.package_name %></td>
                </tr>
              </table>

              <h3 style="color:#3D2B1F;">Before We Arrive:</h3>
              <ul style="color:#555; line-height:1.8;">
                <li>Clear the porch/display area of any items</li>
                <li>Ensure easy access to the front of your home</li>
                <li>No need to be home, but let us know if there are gate codes or special access instructions</li>
              </ul>

              <p style="color:#555; line-height:1.6;">If you need to reschedule, please reply to this email as soon as possible.</p>
              <p style="color:#E8621A; font-weight:bold;">The Sunshine Pumpkins Team</p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="background-color:#3D2B1F; padding:20px; text-align:center;">
              <p style="color:#999; font-size:12px; margin:0;">Sunshine Pumpkins | St. Petersburg, FL</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
