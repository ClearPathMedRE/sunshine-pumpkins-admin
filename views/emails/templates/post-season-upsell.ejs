<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>
<body style="margin:0; padding:0; background-color:#f5f5f5; font-family:Arial,Helvetica,sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5; padding:20px 0;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="background-color:#ffffff; border-radius:8px; overflow:hidden;">
          <!-- Header -->
          <tr>
            <td style="background-color:#E8621A; padding:30px; text-align:center;">
              <h1 style="color:#ffffff; margin:0; font-size:28px;">&#127875; Sunshine Pumpkins</h1>
            </td>
          </tr>
          <!-- Body -->
          <tr>
            <td style="padding:30px;">
              <h2 style="color:#3D2B1F; margin-top:0;">The Season is Winding Down...</h2>
              <p style="color:#555; line-height:1.6;">Hi <%= customer.first_name %>,</p>
              <p style="color:#555; line-height:1.6;">As this pumpkin season comes to a close, we wanted to thank you for being a valued Sunshine Pumpkins customer. We hope your display brought joy to your home and neighborhood!</p>

              <div style="background-color:#E8621A; color:#ffffff; padding:20px; border-radius:8px; text-align:center; margin:20px 0;">
                <p style="margin:0; font-size:18px; font-weight:bold;">Book Early for Next Season!</p>
                <p style="margin:10px 0 0; font-size:14px;">Early bookers get priority scheduling and exclusive pricing</p>
              </div>

              <h3 style="color:#3D2B1F;">Why Book Early?</h3>
              <ul style="color:#555; line-height:1.8;">
                <li>Lock in this year's pricing before any increases</li>
                <li>Get first pick of install dates</li>
                <li>Early access to new package options</li>
                <li>Returning customer discount applied automatically</li>
              </ul>

              <p style="color:#555; line-height:1.6;">Reply to this email or visit our website to reserve your spot for next fall. Spaces fill up fast!</p>

              <p style="color:#E8621A; font-weight:bold;">The Sunshine Pumpkins Team</p>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="background-color:#3D2B1F; padding:20px; text-align:center;">
              <p style="color:#999; font-size:12px; margin:0;">Sunshine Pumpkins | St. Petersburg, FL</p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
