<%
  const isAdmin = locals.currentUser && locals.currentUser.role === 'admin';
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0"><%= partner.name %></h4>
  <div class="d-flex gap-2">
    <a href="/referrals" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Back
    </a>
    <% if (isAdmin) { %>
    <a href="/referrals/<%= partner.id %>/edit" class="btn" style="background-color: var(--pumpkin); color: #fff;">
      <i class="bi bi-pencil me-1"></i> Edit
    </a>
    <% } %>
  </div>
</div>

<!-- Info Card -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="bi bi-person me-2"></i>Partner Information</h5>
  </div>
  <div class="card-body">
    <div class="row">
      <div class="col-md-3 mb-2">
        <small class="text-muted d-block">Email</small>
        <strong><%= partner.email || '-' %></strong>
      </div>
      <div class="col-md-3 mb-2">
        <small class="text-muted d-block">Phone</small>
        <strong><%= partner.phone || '-' %></strong>
      </div>
      <div class="col-md-3 mb-2">
        <small class="text-muted d-block">Company</small>
        <strong><%= partner.company || '-' %></strong>
      </div>
      <div class="col-md-3 mb-2">
        <small class="text-muted d-block">Type</small>
        <% if (partner.partner_type === 'realtor') { %>
          <span class="badge bg-primary">Realtor</span>
        <% } else if (partner.partner_type === 'business') { %>
          <span class="badge bg-info">Business</span>
        <% } else { %>
          <span class="badge bg-secondary">Individual</span>
        <% } %>
      </div>
    </div>
    <div class="row mt-3">
      <div class="col-md-3 mb-2">
        <small class="text-muted d-block">Referral Code</small>
        <code class="fs-5"><%= partner.referral_code %></code>
      </div>
      <div class="col-md-3 mb-2">
        <small class="text-muted d-block">Status</small>
        <span class="badge bg-<%= partner.status === 'active' ? 'success' : 'secondary' %>"><%= partner.status %></span>
      </div>
    </div>
    <div class="row mt-3">
      <div class="col-md-12">
        <small class="text-muted d-block mb-1">Kickback Rates</small>
        <span class="badge bg-light text-dark border me-2">Harvest Hello: $<%= partner.kickback_hello.toFixed(2) %></span>
        <span class="badge bg-light text-dark border me-2">Sunshine Spread: $<%= partner.kickback_spread.toFixed(2) %></span>
        <span class="badge bg-light text-dark border">Grand Harvest: $<%= partner.kickback_harvest.toFixed(2) %></span>
      </div>
    </div>
    <% if (partner.notes) { %>
    <div class="row mt-3">
      <div class="col-md-12">
        <small class="text-muted d-block">Notes</small>
        <p class="mb-0"><%= partner.notes %></p>
      </div>
    </div>
    <% } %>
  </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Total Referrals</div>
        <div class="fs-3 fw-bold" style="color: var(--pumpkin);"><%= partner.stats.total_referrals %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Total Earned</div>
        <div class="fs-3 fw-bold text-success">$<%= partner.stats.total_earned.toFixed(2) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Pending</div>
        <div class="fs-3 fw-bold text-warning">$<%= partner.stats.total_pending.toFixed(2) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Total Paid</div>
        <div class="fs-3 fw-bold text-success">$<%= partner.stats.total_paid.toFixed(2) %></div>
      </div>
    </div>
  </div>
</div>

<!-- Referral History -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Referral History</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Order</th>
            <th>Customer</th>
            <th>Package</th>
            <th>Date</th>
            <th>Kickback</th>
            <th>Payout Status</th>
          </tr>
        </thead>
        <tbody>
          <% if (partner.orders && partner.orders.length) { %>
            <% partner.orders.forEach(function(o) { %>
              <tr>
                <td><a href="/orders/<%= o.id %>">#<%= o.id %></a></td>
                <td><%= o.first_name %> <%= o.last_name %></td>
                <td><%= o.package_name || '-' %></td>
                <td><%= new Date(o.created_at).toLocaleDateString('en-US') %></td>
                <td>$<%= (o.referral_kickback || 0).toFixed(2) %></td>
                <td>
                  <% if (o.payout_status === 'paid') { %>
                    <span class="badge bg-success">Paid</span>
                  <% } else if (o.payout_status === 'pending') { %>
                    <span class="badge bg-warning">Pending</span>
                  <% } else { %>
                    <span class="badge bg-secondary">-</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="6" class="text-center text-muted py-4">No referrals yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Payout History -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white">
    <h5 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Payout History</h5>
  </div>
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Order</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Created</th>
            <th>Paid At</th>
          </tr>
        </thead>
        <tbody>
          <% if (partner.payouts && partner.payouts.length) { %>
            <% partner.payouts.forEach(function(p) { %>
              <tr>
                <td><% if (p.order_id) { %><a href="/orders/<%= p.order_id %>">#<%= p.order_id %></a><% } else { %>-<% } %></td>
                <td>$<%= p.amount.toFixed(2) %></td>
                <td>
                  <span class="badge bg-<%= p.status === 'paid' ? 'success' : (p.status === 'pending' ? 'warning' : 'secondary') %>"><%= p.status %></span>
                </td>
                <td><%= new Date(p.created_at).toLocaleDateString('en-US') %></td>
                <td><%= p.paid_at ? new Date(p.paid_at).toLocaleDateString('en-US') : '-' %></td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="text-center text-muted py-4">No payouts yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
