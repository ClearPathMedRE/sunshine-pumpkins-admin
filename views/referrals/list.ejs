<%
  const isAdmin = locals.currentUser && locals.currentUser.role === 'admin';
%>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0">Referral Partners</h4>
  <div class="d-flex gap-2">
    <a href="/referrals/payouts" class="btn btn-outline-secondary">
      <i class="bi bi-cash-stack me-1"></i> View Payouts
    </a>
    <% if (isAdmin) { %>
    <a href="/referrals/new" class="btn" style="background-color: var(--pumpkin); color: #fff;">
      <i class="bi bi-plus-lg me-1"></i> Add Partner
    </a>
    <% } %>
  </div>
</div>

<!-- Summary Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Total Partners</div>
        <div class="fs-3 fw-bold" style="color: var(--pumpkin);"><%= stats.total_partners %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Total Referrals</div>
        <div class="fs-3 fw-bold" style="color: var(--pumpkin);"><%= stats.total_referrals %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Total Kickbacks Earned</div>
        <div class="fs-3 fw-bold text-success">$<%= stats.total_kickbacks.toFixed(2) %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm text-center">
      <div class="card-body">
        <div class="text-muted small">Pending Payouts</div>
        <div class="fs-3 fw-bold text-warning">$<%= stats.pending_payouts.toFixed(2) %></div>
      </div>
    </div>
  </div>
</div>

<!-- Partners Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Company</th>
            <th>Type</th>
            <th>Code</th>
            <th>Referrals</th>
            <th>Earned</th>
            <th>Pending</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (partners.rows && partners.rows.length) { %>
            <% partners.rows.forEach(function(p) { %>
              <tr>
                <td class="fw-semibold"><a href="/referrals/<%= p.id %>" class="text-decoration-none"><%= p.name %></a></td>
                <td><%= p.company || '-' %></td>
                <td>
                  <% if (p.partner_type === 'realtor') { %>
                    <span class="badge bg-primary">Realtor</span>
                  <% } else if (p.partner_type === 'business') { %>
                    <span class="badge bg-info">Business</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Individual</span>
                  <% } %>
                </td>
                <td><code><%= p.referral_code %></code></td>
                <td><%= p.total_referrals %></td>
                <td class="text-success">$<%= p.total_earned.toFixed(2) %></td>
                <td class="text-warning">$<%= p.pending_kickbacks.toFixed(2) %></td>
                <td>
                  <span class="badge bg-<%= p.status === 'active' ? 'success' : 'secondary' %>"><%= p.status %></span>
                </td>
                <td>
                  <a href="/referrals/<%= p.id %>" class="btn btn-sm btn-outline-primary" title="View">
                    <i class="bi bi-eye"></i>
                  </a>
                  <% if (isAdmin) { %>
                  <a href="/referrals/<%= p.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit">
                    <i class="bi bi-pencil"></i>
                  </a>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="9" class="text-center text-muted py-4">No referral partners yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% if (partners.pages > 1) { %>
<nav class="mt-3">
  <ul class="pagination justify-content-center">
    <% for (let i = 1; i <= partners.pages; i++) { %>
      <li class="page-item <%= partners.page === i ? 'active' : '' %>">
        <a class="page-link" href="/referrals?page=<%= i %><%= filterStatus ? '&status=' + filterStatus : '' %>"><%= i %></a>
      </li>
    <% } %>
  </ul>
</nav>
<% } %>
