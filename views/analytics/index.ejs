<%
  function formatCurrency(val) {
    return '$' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
%>

<!-- Market Selector -->
<div class="d-flex justify-content-end mb-3">
  <%- include('../partials/market-selector') %>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <h6 class="text-muted mb-1">Total Revenue</h6>
        <h3 class="fw-bold" style="color: var(--pumpkin);"><%= formatCurrency(locals.totalRevenue) %></h3>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <h6 class="text-muted mb-1">Order Count</h6>
        <h3 class="fw-bold"><%= locals.orderCount || 0 %></h3>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <h6 class="text-muted mb-1">Avg Order Value</h6>
        <h3 class="fw-bold"><%= formatCurrency(locals.avgOrderValue) %></h3>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-xl-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center">
        <h6 class="text-muted mb-1">Customer Count</h6>
        <h3 class="fw-bold"><%= locals.customerCount || 0 %></h3>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Revenue by Package -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Revenue by Package</div>
      <div class="card-body">
        <canvas id="revenueByPackageChart"></canvas>
      </div>
    </div>
  </div>

  <!-- Revenue by Month -->
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Revenue by Month</div>
      <div class="card-body">
        <canvas id="revenueByMonthChart"></canvas>
      </div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Source Breakdown -->
  <div class="col-lg-5">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Customer Source Breakdown</div>
      <div class="card-body d-flex align-items-center justify-content-center">
        <canvas id="sourceChart" style="max-height: 300px;"></canvas>
      </div>
    </div>
  </div>

  <!-- Add-on Attach Rates -->
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Add-on Attach Rates</div>
      <div class="card-body p-0">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>Add-on</th>
              <th>Orders</th>
              <th>Attach Rate</th>
              <th style="width:40%;"></th>
            </tr>
          </thead>
          <tbody>
            <% if (locals.addonRates && addonRates.length) { %>
              <% addonRates.forEach(function(addon) { %>
                <tr>
                  <td class="fw-semibold"><%= addon.name %></td>
                  <td><%= addon.count %></td>
                  <td><%= addon.rate %>%</td>
                  <td>
                    <div class="progress" style="height: 20px;">
                      <div class="progress-bar" role="progressbar" style="width: <%= addon.rate %>%; background-color: var(--pumpkin);" aria-valuenow="<%= addon.rate %>" aria-valuemin="0" aria-valuemax="100">
                        <%= addon.rate %>%
                      </div>
                    </div>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr><td colspan="4" class="text-center text-muted py-3">No add-on data available</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Revenue by Market -->
<div class="row g-3 mb-4">
  <div class="col-12">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-header bg-white fw-semibold">Revenue by Market</div>
      <div class="card-body">
        <canvas id="revenueByMarketChart"></canvas>
      </div>
    </div>
  </div>
</div>

<script>
  const revenueByMarket = <%- locals.revenueByMarket || '[]' %>;
  const revenueByPackage = <%- JSON.stringify(locals.revenueByPackage || {}) %>;
  const revenueByMonth = <%- JSON.stringify(locals.revenueByMonth || {}) %>;
  const sourceBreakdown = <%- JSON.stringify(locals.sourceBreakdown || {}) %>;

  // Revenue by Package - Bar Chart
  if (document.getElementById('revenueByPackageChart')) {
    new Chart(document.getElementById('revenueByPackageChart'), {
      type: 'bar',
      data: {
        labels: Object.keys(revenueByPackage),
        datasets: [{
          label: 'Revenue ($)',
          data: Object.values(revenueByPackage),
          backgroundColor: '#E8621A',
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: function(v) { return '$' + v.toLocaleString(); } }
          }
        }
      }
    });
  }

  // Revenue by Month - Line Chart
  if (document.getElementById('revenueByMonthChart')) {
    new Chart(document.getElementById('revenueByMonthChart'), {
      type: 'line',
      data: {
        labels: Object.keys(revenueByMonth),
        datasets: [{
          label: 'Revenue ($)',
          data: Object.values(revenueByMonth),
          borderColor: '#E8621A',
          backgroundColor: '#E8621A20',
          fill: true,
          tension: 0.3
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: function(v) { return '$' + v.toLocaleString(); } }
          }
        }
      }
    });
  }

  // Source Breakdown - Pie Chart
  if (document.getElementById('sourceChart')) {
    const sourceColors = ['#E8621A', '#3D2B1F', '#0d6efd', '#198754', '#ffc107', '#6f42c1', '#dc3545'];
    new Chart(document.getElementById('sourceChart'), {
      type: 'pie',
      data: {
        labels: Object.keys(sourceBreakdown),
        datasets: [{
          data: Object.values(sourceBreakdown),
          backgroundColor: sourceColors.slice(0, Object.keys(sourceBreakdown).length),
          borderWidth: 0
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { position: 'bottom', labels: { boxWidth: 12 } }
        }
      }
    });
  }

  // Revenue by Market - Bar Chart
  if (document.getElementById('revenueByMarketChart') && revenueByMarket.length) {
    const marketColors = ['#E8621A', '#3D2B1F', '#0d6efd', '#198754', '#ffc107', '#6f42c1', '#dc3545'];
    new Chart(document.getElementById('revenueByMarketChart'), {
      type: 'bar',
      data: {
        labels: revenueByMarket.map(function(m) { return m.market_name || 'Unknown'; }),
        datasets: [{
          label: 'Revenue ($)',
          data: revenueByMarket.map(function(m) { return m.revenue; }),
          backgroundColor: marketColors.slice(0, revenueByMarket.length),
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            ticks: { callback: function(v) { return '$' + v.toLocaleString(); } }
          }
        }
      }
    });
  }
</script>
