<%
  const statusColors = {
    booked: 'primary', photo_requested: 'warning', design_prep: 'info',
    scheduled: 'secondary', installed: 'success', completed: 'success', cancelled: 'danger'
  };
  const statusFlow = {
    booked: ['photo_requested', 'cancelled'],
    photo_requested: ['design_prep', 'cancelled'],
    design_prep: ['scheduled', 'cancelled'],
    scheduled: ['installed', 'cancelled'],
    installed: ['completed', 'cancelled'],
    completed: [],
    cancelled: []
  };
  function statusBadge(status) {
    const color = statusColors[status] || 'secondary';
    const label = (status || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    return '<span class="badge bg-' + color + '">' + label + '</span>';
  }
  function formatCurrency(val) {
    return '$' + Number(val || 0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }
  const isAdmin = locals.currentUser && currentUser.role === 'admin';
  const nextStatuses = statusFlow[order.status] || [];
%>

<div class="row g-4">
  <!-- Left Column -->
  <div class="col-lg-7">
    <!-- Customer Info -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-person me-1"></i> Customer Information
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-sm-6 mb-2">
            <small class="text-muted d-block">Name</small>
            <a href="/customers/<%= order.customer_id %>"><%= order.customer_name %></a>
          </div>
          <div class="col-sm-6 mb-2">
            <small class="text-muted d-block">Email</small>
            <%= order.customer_email %>
          </div>
          <div class="col-sm-6 mb-2">
            <small class="text-muted d-block">Phone</small>
            <%= order.customer_phone || 'N/A' %>
          </div>
          <div class="col-sm-6 mb-2">
            <small class="text-muted d-block">Address</small>
            <%= order.customer_address || 'N/A' %>
          </div>
        </div>
      </div>
    </div>

    <!-- Order Items -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-box-seam me-1"></i> Order Items
      </div>
      <div class="card-body p-0">
        <table class="table mb-0">
          <thead class="table-light">
            <tr>
              <th>Item</th>
              <th>Type</th>
              <th class="text-end">Price</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong><%= order.package_name %></strong></td>
              <td><span class="badge bg-primary">Package</span></td>
              <td class="text-end"><%= formatCurrency(order.package_price) %></td>
            </tr>
            <% if (locals.addons && addons.length) { %>
              <% addons.forEach(function(addon) { %>
                <tr>
                  <td><%= addon.name %></td>
                  <td><span class="badge bg-info">Add-on</span></td>
                  <td class="text-end"><%= formatCurrency(addon.price) %></td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
          <tfoot class="table-light">
            <tr>
              <td colspan="2" class="text-end fw-bold">Total</td>
              <td class="text-end fw-bold"><%= formatCurrency(order.total) %></td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>
  </div>

  <!-- Right Column -->
  <div class="col-lg-5">
    <!-- Status Card -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-flag me-1"></i> Order Status
      </div>
      <div class="card-body">
        <div class="d-flex align-items-center mb-3">
          <span class="me-2">Current Status:</span>
          <%- statusBadge(order.status) %>
        </div>
        <% if (nextStatuses.length > 0) { %>
          <form action="/orders/<%= order.id %>/status" method="POST">
            <div class="input-group">
              <select name="status" class="form-select">
                <option value="">Update status...</option>
                <% nextStatuses.forEach(function(s) { %>
                  <option value="<%= s %>"><%= s.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></option>
                <% }); %>
              </select>
              <button type="submit" class="btn btn-outline-secondary">Update</button>
            </div>
          </form>
        <% } %>
      </div>
    </div>

    <!-- Status History -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-clock-history me-1"></i> Status History
      </div>
      <div class="card-body">
        <% if (locals.statusHistory && statusHistory.length) { %>
          <div class="timeline">
            <% statusHistory.forEach(function(entry, i) { %>
              <div class="d-flex mb-3">
                <div class="flex-shrink-0 me-3">
                  <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:32px;height:32px;background-color:<%= i === 0 ? '#E8621A' : '#dee2e6' %>;">
                    <i class="bi bi-check2 small" style="color:<%= i === 0 ? '#fff' : '#6c757d' %>;"></i>
                  </div>
                </div>
                <div>
                  <div class="fw-semibold"><%= (entry.status || '').replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></div>
                  <small class="text-muted"><%= new Date(entry.created_at).toLocaleString('en-US') %> &mdash; <%= entry.changed_by || 'System' %></small>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-muted mb-0">No status history available</p>
        <% } %>
      </div>
    </div>

    <!-- Notes -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-sticky me-1"></i> Notes
      </div>
      <div class="card-body">
        <% if (locals.notes && notes.length) { %>
          <% notes.forEach(function(note) { %>
            <div class="border-bottom pb-2 mb-2">
              <p class="mb-1"><%= note.content %></p>
              <small class="text-muted"><%= note.author %> &mdash; <%= new Date(note.created_at).toLocaleString('en-US') %></small>
            </div>
          <% }); %>
        <% } else { %>
          <p class="text-muted">No notes yet</p>
        <% } %>
        <form action="/orders/<%= order.id %>/notes" method="POST" class="mt-3">
          <div class="input-group">
            <input type="text" name="content" class="form-control" placeholder="Add a note..." required>
            <button type="submit" class="btn btn-outline-secondary">
              <i class="bi bi-plus"></i> Add
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Action Buttons -->
<div class="d-flex gap-2 mt-2">
  <% if (isAdmin) { %>
    <a href="/orders/<%= order.id %>/edit" class="btn btn-outline-primary">
      <i class="bi bi-pencil me-1"></i> Edit / Amend
    </a>
    <% if (order.status !== 'cancelled') { %>
      <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#cancelModal">
        <i class="bi bi-x-circle me-1"></i> Cancel Order
      </button>
    <% } %>
  <% } %>
  <a href="/orders" class="btn btn-outline-secondary ms-auto">
    <i class="bi bi-arrow-left me-1"></i> Back to Orders
  </a>
</div>

<% if (isAdmin && order.status !== 'cancelled') { %>
<!-- Cancel Confirmation Modal -->
<div class="modal fade" id="cancelModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/orders/<%= order.id %>/cancel" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">Cancel Order #<%= order.order_number || order.id %></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Are you sure you want to cancel this order? This action cannot be undone.</p>
          <div class="mb-3">
            <label for="cancelReason" class="form-label">Reason for cancellation</label>
            <textarea name="reason" id="cancelReason" class="form-control" rows="3" required placeholder="Enter reason..."></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <button type="submit" class="btn btn-danger">Confirm Cancellation</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>
