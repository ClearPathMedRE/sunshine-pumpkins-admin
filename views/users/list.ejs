<div class="d-flex justify-content-between align-items-center mb-4">
  <div></div>
  <a href="/users/new" class="btn" style="background-color: var(--pumpkin); color: #fff;">
    <i class="bi bi-plus-lg me-1"></i> Add User
  </a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Created</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (locals.users && users.length) { %>
            <% users.forEach(function(user) { %>
              <tr>
                <td class="fw-semibold"><%= user.name %></td>
                <td><%= user.email %></td>
                <td>
                  <span class="badge bg-<%= user.role === 'admin' ? 'danger' : 'secondary' %>"><%= user.role %></span>
                </td>
                <td><%= new Date(user.created_at).toLocaleDateString('en-US') %></td>
                <td>
                  <a href="/users/<%= user.id %>/edit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Edit
                  </a>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="5" class="text-center text-muted py-4">No users found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
