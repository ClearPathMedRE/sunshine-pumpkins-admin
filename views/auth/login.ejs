<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | Sunshine Pumpkins Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    :root {
      --pumpkin: #E8621A;
      --bark: #3D2B1F;
    }
    body {
      background-color: var(--bark);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      max-width: 420px;
      width: 100%;
    }
    .btn-pumpkin {
      background-color: var(--pumpkin);
      border-color: var(--pumpkin);
      color: #fff;
    }
    .btn-pumpkin:hover {
      background-color: #d4570f;
      border-color: #d4570f;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="card shadow-lg border-0">
      <div class="card-body p-5">
        <div class="text-center mb-4">
          <h2 class="fw-bold" style="color: var(--pumpkin);">&#127875; Sunshine Pumpkins Admin</h2>
          <p class="text-muted">Sign in to your account</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>

        <form action="/login" method="POST">
          <div class="mb-3">
            <label for="email" class="form-label">Email address</label>
            <input type="email" class="form-control" id="email" name="email" required autofocus placeholder="you@example.com">
          </div>
          <div class="mb-3">
            <label for="password" class="form-label">Password</label>
            <input type="password" class="form-control" id="password" name="password" required placeholder="Your password">
          </div>
          <div class="d-grid">
            <button type="submit" class="btn btn-pumpkin btn-lg">Sign In</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
